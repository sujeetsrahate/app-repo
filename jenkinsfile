pipeline {
    agent any

    environment {
        IMAGE = "sujeetsr07/app"
        DOCKERHUB_CREDENTIALS = 'docker-hub-cred'
        GIT_CREDENTIALS = 'git-creds'
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/sujeetsrahate/app-repo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t $IMAGE:$BUILD_NUMBER ."
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKERHUB_CREDENTIALS}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                }
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push $IMAGE:$BUILD_NUMBER"
            }
        }

        stage('Update Deployment YAML') {
            steps {
                sh """
                sed -i 's|image:.*|image: $IMAGE:$BUILD_NUMBER|' k8s/deployment.yaml
                """
            }
        }

        stage('Commit & Push Changes') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${GIT_CREDENTIALS}",
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh """
                    git config user.email "jenkins@example.com"
                    git config user.name "jenkins"

                    git add .
                    git commit -m "Update image to $BUILD_NUMBER" || echo "No changes"

                    git push https://$GIT_USER:$GIT_PASS@github.com/sujeetsrahate/app-repo.git HEAD:main
                    """
                }
            }
        }
    }
}